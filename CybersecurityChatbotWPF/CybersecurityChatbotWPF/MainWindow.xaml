<Window x:Class="CybersecurityChatbotWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot" 
        Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Window.Resources>
        <!-- Styles for better UI -->
        <Style x:Key="ChatBubbleUser" TargetType="Border">
            <Setter Property="Background" Value="#2B5797"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Margin" Value="10,5,50,5"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>

        <Style x:Key="ChatBubbleBot" TargetType="Border">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Margin" Value="50,5,10,5"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>

        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2B5797"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E3A5F"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with ASCII Art -->
        <Border Grid.Row="0" Background="#0D2B40" Padding="15">
            <StackPanel>
                <TextBlock x:Name="AsciiArtBlock" 
                           FontFamily="Consolas" 
                           FontSize="10" 
                           Foreground="#4CAF50"
                           TextAlignment="Center"
                           Text="
    ╔════════════════════════════════════════════════════════╗
    ║          ██████╗██╗   ██╗██████╗ ███████╗██████╗       ║
    ║         ██╔════╝╚██╗ ██╔╝██╔══██╗██╔════╝██╔══██╗      ║
    ║         ██║      ╚████╔╝ ██████╔╝█████╗  ██████╔╝      ║
    ║         ██║       ╚██╔╝  ██╔══██╗██╔══╝  ██╔══██╗      ║
    ║         ╚██████╗   ██║   ██████╔╝███████╗██║  ██║      ║
    ║          ╚═════╝   ╚═╝   ╚═════╝ ╚══════╝╚═╝  ╚═╝      ║
    ║                                                        ║
    ║         Cybersecurity Awareness Bot v2.0              ║
    ║           Your Guide to Online Safety                 ║
    ╚════════════════════════════════════════════════════════╝"/>
                <TextBlock Text="Cybersecurity Awareness Bot" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="#4CAF50"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Chat Area -->
        <ScrollViewer x:Name="ChatScrollViewer" 
                      Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto"
                      Background="#2D2D2D">
            <StackPanel x:Name="ChatStackPanel" 
                        Margin="10" 
                        Orientation="Vertical"/>
        </ScrollViewer>

        <!-- Input Area -->
        <Border Grid.Row="2" 
                Background="#252526" 
                Padding="10" 
                BorderBrush="#3E3E3E" 
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="MessageTextBox" 
                         Grid.Column="0"
                         Height="40" 
                         FontSize="14"
                         Background="#3E3E3E" 
                         Foreground="White"
                         BorderThickness="0"
                         Padding="10,8"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         KeyDown="MessageTextBox_KeyDown">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <Button x:Name="SendButton" 
                        Grid.Column="1"
                        Content="Send" 
                        Style="{StaticResource SendButtonStyle}"
                        Margin="10,0,0,0"
                        Height="40"
                        Width="80"
                        Click="SendButton_Click"/>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay" 
                Grid.RowSpan="3" 
                Background="#80000000" 
                Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🤖 Bot is thinking..." 
                           FontSize="16" 
                           Foreground="White"
                           FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>